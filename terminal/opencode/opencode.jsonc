{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "envsitter-guard",
    "@khalilgharbaoui/opencode-claude-code-plugin",
    "oh-my-openagent@latest"
  ],
  "agent": {
    "explore": {
      "disable": true,
    },
    "general": {
      "disable": true,
    },
  },
  "lsp": true,
  "mcp": {
    "git": {
      "type": "local",
      "command": ["/Users/vkwhm/.nix-profile/bin/mcp-server-git"],
    },
    "github": {
      "type": "local",
      "command": [
        "sh",
        "-c",
        "GITHUB_PERSONAL_ACCESS_TOKEN=$(/Users/vkwhm/.nix-profile/bin/gh auth token) exec /Users/vkwhm/.nix-profile/bin/bunx -y @modelcontextprotocol/server-github",
      ],
    },
  },
}
