{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["envsitter-guard", "oh-my-openagent@latest"],
  "agent": {
    "explore": {
      "disable": true,
    },
    "general": {
      "disable": true,
    },
  },
  "small_model": "opencode-go/deepseek-v4-flash",
  "lsp": true,
  "mcp": {
    "git": {
      "type": "local",
      "command": ["/Users/vkwhm/.nix-profile/bin/mcp-server-git"],
    },
    "github": {
      "type": "local",
      "command": [
        "sh",
        "-c",
        "GITHUB_PERSONAL_ACCESS_TOKEN=$(/Users/vkwhm/.nix-profile/bin/gh auth token) exec /Users/vkwhm/.nix-profile/bin/bunx -y @modelcontextprotocol/server-github",
      ],
    },
  },
}
